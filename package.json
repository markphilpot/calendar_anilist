    "class-variance-authority": "^0.7.1",
    "classnames": "^2.3.1",
    "clsx": "^2.1.1",
    "graphql": "^15.5.3",
    "graphql-request": "^7.4.0",
    "lucide-react": "^0.562.0",
    "luxon": "^2.3.1",
    "ramda": "^0.28.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^4.3.1",
    "react-toastify": "^8.2.0",
    "react-use": "^17.3.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.1.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/luxon": "^2.3.1",
    "@types/node": "^22.0.0",
    "@types/ramda": "^0.28.7",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "prettier": "^2.8.2",
    "prettier-plugin-tailwindcss": "^0.2.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1"
  },
  "resolutions": {
    "graphql": "^15.5.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*\"",
    "format:check": "prettier --check \"src/**/*\"",
    "lint": "pnpm lint:tsc && pnpm lint:es",
    "lint:es": "eslint .",
    "lint:tsc": "tsc --noEmit",
    "update-schema": "curl -i -X POST https://graphql.anilist.co -H \"Content-Type: application/graphql\" -d @assets/introspection.graphql",
    "gql-codegen": "graphql-codegen && prettier --write src/gql/ --cache"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
