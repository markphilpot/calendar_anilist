{
  "name": "calendar_anilist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@mphilpot/react-circular-menu": "^2.3.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/query-sync-storage-persister": "^5.90.20",
