{
  "name": "calendar_anilist",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/client": "^3.5.10",
    "@fontsource/lato": "^4.5.5",
    "@fontsource/source-sans-pro": "^4.5.6",
    "@fontsource/zen-old-mincho": "^4.5.8",
    "@headlessui/react": "^1.7.7",
    "@mphilpot/react-circular-menu": "^2.3.7",
    "apollo3-cache-persist": "^0.14.0",
    "classnames": "^2.3.1",
    "graphql": "^15.5.3",
    "luxon": "^2.3.1",
    "ramda": "^0.28.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-icons": "^4.3.1",
    "react-router-dom": "^6.3.0",
    "react-toastify": "^8.2.0",
    "react-use": "^17.3.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.1.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/luxon": "^2.3.1",
    "@types/node": "^22.0.0",
    "@types/ramda": "^0.28.7",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "prettier": "^2.8.2",
    "prettier-plugin-tailwindcss": "^0.2.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "resolutions": {
    "graphql": "^15.5.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*\"",
    "format:check": "prettier --check \"src/**/*\"",
    "lint": "pnpm lint:tsc && pnpm lint:es",
    "lint:es": "eslint .",
    "lint:tsc": "tsc --noEmit",
    "update-schema": "curl -i -X POST https://graphql.anilist.co -H \"Content-Type: application/graphql\" -d @assets/introspection.graphql",
    "gql-codegen": "graphql-codegen && prettier --write src/gql/ --cache"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
